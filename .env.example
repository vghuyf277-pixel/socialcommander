# ─── Database ────────────────────────────────────────────────────────────────
# Automatically provided by Replit — do not set manually
DATABASE_URL=postgresql://user:password@localhost:5432/socialcommander

# ─── AI Content Generation ───────────────────────────────────────────────────
# Get a free key at https://console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here

# Fallback: OpenAI-compatible key (if not using Groq)
# OPENAI_API_KEY=sk-your-openai-key-here

# ─── GitHub Integration ───────────────────────────────────────────────────────
# Personal Access Token with `repo` scope
# https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_github_token_here

# Target repo in "owner/repo" format
GITHUB_REPO=yourusername/socialcommander

# Branch to push to (default: main)
GITHUB_BRANCH=main

# ─── Session ─────────────────────────────────────────────────────────────────
SESSION_SECRET=change_me_to_a_long_random_string

# ─── Per-Account Proxies ─────────────────────────────────────────────────────
# Proxy URLs are stored per-account in the database (proxyConfig field)
# Format: http://user:pass@host:port  or  socks5://host:port

# ─── Platform OAuth ──────────────────────────────────────────────────────────
# Twitter/X API (for future direct API integration)
# TWITTER_CLIENT_ID=
# TWITTER_CLIENT_SECRET=

# Reddit API (for future direct API integration)
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=
